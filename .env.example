# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║              MIOS — On-Premise Environment Configuration                     ║
# ║                                                                              ║
# ║  Copy this file to .env and fill in every value marked with <CHANGE_ME>.     ║
# ║  Secrets marked [GENERATED] are auto-filled by install.sh.                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Image Registry ───────────────────────────────────────────────────────────
# Registry where MIOS images are hosted (set by install.sh from release.json).
IMAGE_REGISTRY=ghcr.io/mios-ai
IMAGE_TAG=latest

# ─── Domain ───────────────────────────────────────────────────────────────────
# The base domain used for all subdomains.
# Services are exposed at: app.<DOMAIN>, api.<DOMAIN>, ai.<DOMAIN>, etc.
DOMAIN_NAME=mios.example.com

# Ports bound on the host (change if 80/443 are already taken).
HTTP_PORT=80
HTTPS_PORT=443

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.${DOMAIN_NAME}
NEXT_PUBLIC_AI_URL=https://ai.${DOMAIN_NAME}
FRONTEND_URL=https://app.${DOMAIN_NAME}

# ─── Backend ──────────────────────────────────────────────────────────────────
BACK_CONTAINER_PORT=3000

# ─── Business Database (PostgreSQL + pgvector) ────────────────────────────────
DB_BACK_USER=mios_user
# [GENERATED] Strong random password — set by install.sh
DB_BACK_PASSWORD=<CHANGE_ME>
DB_BACK_NAME=mios_business
DB_BACK_PORT=5432
DATABASE_URL=postgresql://${DB_BACK_USER}:${DB_BACK_PASSWORD}@db-back:${DB_BACK_PORT}/${DB_BACK_NAME}?schema=public

# ─── AI Database (PostgreSQL + pgvector) ──────────────────────────────────────
DB_AI_USER=mios_ai_user
# [GENERATED] Strong random password — set by install.sh
DB_AI_PASSWORD=<CHANGE_ME>
DB_AI_NAME=mios_ai_vectors
DB_AI_PORT=5432
AI_DATABASE_URL=postgresql://${DB_AI_USER}:${DB_AI_PASSWORD}@db-ai:${DB_AI_PORT}/${DB_AI_NAME}

# ─── Redis ────────────────────────────────────────────────────────────────────
# [GENERATED] Strong random password — set by install.sh
REDIS_PASSWORD=<CHANGE_ME>
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:${REDIS_PORT}
# Max memory Redis is allowed to use. Use mb/gb suffix.
REDIS_MAX_MEMORY=256mb

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ROOT_USER=mios_minio_admin
# [GENERATED] Strong random password — set by install.sh
MINIO_ROOT_PASSWORD=<CHANGE_ME>
MINIO_ENDPOINT=http://minio:9000

# ─── AI Service ───────────────────────────────────────────────────────────────
AI_CONTAINER_PORT=8000

# AI provider: "local" uses Ollama (no internet required), "openai" uses OpenAI.
AI_PROVIDER=local

# Model to load on startup when AI_PROVIDER=local.
# Examples: llama3.2, mistral, gemma2:9b, phi3
AI_MODEL=llama3.2

# Only required when AI_PROVIDER=openai.
OPENAI_API_KEY=

# ─── Internal Security ────────────────────────────────────────────────────────
# [GENERATED] Shared secret between backend and internal services.
# Must be the same across all services. Generated by install.sh.
INTERNAL_API_KEY=<CHANGE_ME>

# ─── Connectors (optional — only if started with --profile connectors) ────────

# Slack
SLACK_BOT_TOKEN=xoxb-<CHANGE_ME>
SLACK_SIGNING_SECRET=<CHANGE_ME>
SLACK_CLIENT_ID=<CHANGE_ME>
SLACK_CLIENT_SECRET=<CHANGE_ME>
SLACK_REDIRECT_URI=https://slack.${DOMAIN_NAME}/oauth/slack/callback

# GitHub
GITHUB_CLIENT_ID=<CHANGE_ME>
GITHUB_CLIENT_SECRET=<CHANGE_ME>
GITHUB_REDIRECT_URI=https://github.${DOMAIN_NAME}/oauth/github/callback

# Microsoft
MICROSOFT_CLIENT_ID=<CHANGE_ME>
MICROSOFT_CLIENT_SECRET=<CHANGE_ME>
MICROSOFT_REDIRECT_URI=https://microsoft.${DOMAIN_NAME}/oauth/microsoft/callback

# Google
GOOGLE_CLIENT_ID=<CHANGE_ME>
GOOGLE_CLIENT_SECRET=<CHANGE_ME>
GOOGLE_REDIRECT_URI=https://google.${DOMAIN_NAME}/oauth/google/callback

# ─── Internal Service URLs (do not change unless you rename containers) ────────
INTERNAL_BACKEND_URL=http://app-back:3000
MICROSERVICE_PING_INTERVAL=60
SLACK_CONNECTOR_URL=http://app-conn-slack:3000
GITHUB_CONNECTOR_URL=http://app-conn-github:3000
MICROSOFT_CONNECTOR_URL=http://app-conn-microsoft:3000
GOOGLE_CONNECTOR_URL=http://app-conn-google:3000

# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=mios
