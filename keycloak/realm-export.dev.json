{
  "realm": "mios",
  "displayName": "MIOS",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "none",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "user",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRole": {
    "name": "user",
    "composite": false,
    "clientRole": false,
    "containerId": "mios"
  },
  "clients": [
    {
      "clientId": "mios-app",
      "name": "MIOS Application",
      "enabled": true,
      "publicClient": false,
      "secret": "mios-dev-client-secret-2026",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://app.mios.local/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "https://app.mios.local",
        "http://localhost:3000"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://app.mios.local/*##http://localhost:3000/*"
      },
      "protocolMappers": [
        {
          "name": "audience-mios-app",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mios-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@mios.local",
      "firstName": "Alice",
      "lastName": "Anderson",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "bob",
      "email": "bob@mios.local",
      "firstName": "Bob",
      "lastName": "Brown",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ],
  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 90,
      "config": {}
    }
  ]
}
